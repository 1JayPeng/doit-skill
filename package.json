  "main": "SKILL.md",
  "keywords": [
    "skill",
    "claude-code",
    "tdd",
    "workflow",
    "spec-driven",
    "agentic"
  ],
  "author": "alice",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/1JayPeng/doit-skill"
  },
  "bugs": {
    "url": "https://github.com/1JayPeng/doit-skill/issues"
  },
  "homepage": "https://github.com/1JayPeng/doit-skill#readme",
  "dependencies": {
    "skills": {
      "grill-me": "bundled",
      "tdd": "bundled",
      "diagnose": "bundled",
      "prototype": "bundled",
      "handoff": "bundled",
      "improve-codebase-architecture": "bundled"
    },
    "optionalSkills": {
      "code-review": "built-in Claude Code skill",
      "security-review": "built-in Claude Code skill",
      "verify": "built-in Claude Code skill",
      "caveman": "built-in Claude Code skill",
      "find-skills": "built-in Claude Code skill",
      "write-a-skill": "built-in Claude Code skill"
    },
    "tools": {
      "rtk": "cargo install rtk",
      "uv": "pip install uv",
      "codegraph": "npx @anthropic/codegraph init",
      "code-review-graph": "pip install code-review-graph",
      "context-mode": "npx @anthropic/context-mode"
    }
  }
}
